APP_NAME=SmartPunch
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=smartpunch
DB_USERNAME=smartpunch
DB_PASSWORD=smartpunch

# Or use a connection string (Render sets this automatically):
# DATABASE_URL=postgresql://smartpunch:smartpunch@db:5432/smartpunch

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync
LOG_CHANNEL=stack

# Anthropic API — required for AI image analysis and report generation.
# Without this key, the app still works but AI features return fallback responses.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Frontend origin — used by CORS middleware to allow cross-origin requests.
FRONTEND_URL=http://localhost:4200
